# Certbot
# USER_EMAIL="mail@example.com"

# OpenConnect server
TZ="Europe/Moscow"
SRV_PORT="443"
SRV_CN="example.com"
SRV_CA="Example CA"
IPV4_NET="10.10.10.0"
IPV4_MASK="255.255.255.0"
DNS1="8.8.8.8"
DNS2="8.8.4.4"
# CAMOUFLAGE=false
# CAMOUFLAGE_SECRET="secretword"
# CAMOUFLAGE_REALM="Welcome to admin panel"

# OTP
# OTP_ENABLE="true"
# OTP_SEND_BY_EMAIL="true"
# MSMTP_HOST="smtp.example.com"
# MSMTP_PORT="465"
# MSMTP_USER="mail@example.com"
# MSMTP_PASSWORD="SuPeRsEcReTpAsSwOrD"
# MSMTP_FROM="mail@example.com"
# OTP_SEND_BY_TELEGRAM="true"
# TG_TOKEN="1234567890:QWERTYuio-PA1DFGHJ2_KlzxcVBNmqWEr3t"

# OpenConnect client
# OCCLIENT_ENABLE=true
# OCCLIENT_TYPE=docker # docker|host
# OCCLIENT_IFACE="tun10"
# OCCLIENT_CHECK_HOST_INTERVAL=5
# OCCLIENT_CHECK_HOST_THRESHOLD=3

# OCCLIENT_COUNT=2

# OCCLIENT_0_SSL_FLAG=true
# OCCLIENT_0_SERVER="ocserv1.example.com"
# OCCLIENT_0_SERVER_PORT=443
# OCCLIENT_0_CERT_FILE="/etc/openconnect/ocserv1.p12"
# OCCLIENT_0_CERT_PASS="p12SecretInBase64encode" 
# OCCLIENT_0_CHECK_HOST="10.120.120.1"

# OCCLIENT_1_SSL_FLAG=false
# OCCLIENT_1_SERVER="ocserv2.example.com"
# OCCLIENT_1_SERVER_PORT=443
# OCCLIENT_1_CERT_FILE="/etc/openconnect/ocserv2.p12"
# OCCLIENT_1_CERT_PASS="p12SecretInBase64encode"
# OCCLIENT_1_CHECK_HOST="10.130.130.1"

# Dnsmasq
